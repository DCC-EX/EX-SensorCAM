# --- General Operating System Files ---
.DS_Store             # macOS
.Trashes              # macOS
Thumbs.db             # Windows
desktop.ini           # Windows
*.swp                 # Vim temporary files
*~                    # Emacs temporary files
*#* # Common editor backup patterns

# --- Build/Compilation Artifacts ---
*.o                   # Object files
*.d                   # Dependency files
*.elf                 # Executable/firmware file (often generated by PlatformIO)
*.hex                 # Intel HEX firmware format
*.bin                 # Binary firmware format
*.map                 # Linker map files
*.srec                # S-Record firmware format

# --- PlatformIO Files ---
.pio/                 # PlatformIO's main environment folder (crucial!)

# --- IDE and Editor Files (VSCode/PlatformIO) ---
.vscode/

# --- Custom/Local User Configuration ---
configCAM.h              # User-specific configuration file
